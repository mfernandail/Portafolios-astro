---
import { basics } from '@cv'
import Section from '@/components/Section.astro'

import Mail from '@/icons/Email.astro'
import Number from '@/icons/Number.astro'
import LinkedIn from '@/icons/Linkedin.astro'
import Github from '@/icons/Github.astro'
---

<Section>
  <div class="container">
    <div class="info">
      <h1>{basics.name}</h1>
      <h2>{basics.label}</h2>
      <span>📍 {basics.location.city}, {basics.location.region}</span>
      <footer>
        <a
          href={`mailto:${basics.email}`}
          title={`Enviar un correo electrónico a ${basics.name} al correo ${basics.email}`}
          target="_blank"
          rel="noopener noreferrer"
        >
          <Mail />
        </a>
        <a
          href={`tel:${basics.phone}`}
          title={`Llamar por teléfono a ${basics.name} al número ${basics.phone}`}
          target="_blank"
          rel="noopener noreferrer"
        >
          <Number />
        </a>

        {
          basics.profiles.map(({ network, url, username }) => {
            //const Icon = SOCIAL_ICONS[network]
            return (
              <a
                href={url}
                title={`Visitar el perfil de ${basics.name} en ${network}`}
                target="_blank"
                rel="noopener noreferrer"
              >
                {network === 'LinkedIn' && <LinkedIn />}
                {network === 'GitHub' && <Github />}
              </a>
            )
          })
        }
      </footer>
    </div>

    <figure>
      <img src={basics.image} alt={`Foto de ${basics.name}`} />
    </figure>
  </div>
</Section>

<style>
  .container {
    align-items: center;
    display: flex;
    flex-direction: row;
    gap: 1rem;
    justify-content: space-between;
  }

  h1 {
    font-size: 2rem;
  }

  h2 {
    color: #4444;
    font-size: 1.1rem;
    font-weight: 500;
    text-wrap: balance;
  }

  img {
    aspect-ratio: 1/1;
    border-radius: 6px;
    object-fit: cover;
    width: 100px;
  }
</style>
