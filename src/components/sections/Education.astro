---
import Section from '../Section.astro'
import { education } from '@cv'
---

<Section title="Education">
  <ul>
    <li>
      <article>
        <header>
          <div>
            <h3>{education.institution}</h3>
            <h4>{education.area}</h4>
          </div>
          <time> {new Date(education.startDate).getFullYear()} - {new Date(education.endDate).getFullYear()} </time>
        </header>
      </article>
    </li>
  </ul>

  <hr />
</Section>

<style>
  ul {
    margin-top: 10px;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    color: #000;
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  article h3 {
    font-weight: 500
    color: #111;
  }

  article time {
    color: #666;
    font-size: 0.8rem;
  }

  hr {
    margin-top: 20px;
    border: none;
    border-top: 1px dotted #d0d0d0a3;
  }
</style>