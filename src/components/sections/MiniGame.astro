---
import Section from '../Section.astro'
---

<Section title="Mini Game">
  <div class="rps">
    <header>
      <p>Play Rock, Paper, Scissors against the computer.</p>
      <div class="scoreboard" aria-live="polite">
        <div>
          <span>Player</span>
          <strong id="player-score">0</strong>
        </div>
        <div>
          <span>CPU</span>
          <strong id="cpu-score">0</strong>
        </div>
      </div>
    </header>

    <div class="result" role="status" aria-live="polite">
      Press a button to get started.
    </div>

    <div class="choices">
      <button type="button" data-choice="rock">🪨 Rock</button>
      <button type="button" data-choice="paper">📄 Paper</button>
      <button type="button" data-choice="scissors">✂️ Scissors</button>
    </div>

    <button type="button" class="reset" id="reset-game">Reset score</button>
  </div>
</Section>

<script is:inline>
  const buttons = document.querySelectorAll('[data-choice]')
  const resultEl = document.querySelector('.result')
  const playerScoreEl = document.getElementById('player-score')
  const cpuScoreEl = document.getElementById('cpu-score')
  const resetBtn = document.getElementById('reset-game')

  const rules = {
    rock: 'scissors',
    paper: 'rock',
    scissors: 'paper',
  }

  let playerScore = 0
  let cpuScore = 0

  buttons.forEach((button) => {
    button.addEventListener('click', () => {
      playRound(button.dataset.choice)
    })
  })

  resetBtn?.addEventListener('click', resetScores)

  function playRound(playerChoice) {
    const cpuChoice = getCpuChoice()

    if (playerChoice === cpuChoice) {
      updateResult(`Draw: both picked ${playerChoice}.`)
      return
    }

    const playerWins = rules[playerChoice] === cpuChoice

    if (playerWins) {
      playerScore += 1
      updateScores()
      updateResult(`You win: ${playerChoice} beats ${cpuChoice}.`)
    } else {
      cpuScore += 1
      updateScores()
      updateResult(`You lose: ${cpuChoice} beats ${playerChoice}.`)
    }
  }

  function getCpuChoice() {
    const options = Object.keys(rules)
    const index = Math.floor(Math.random() * options.length)
    return options[index]
  }

  function updateScores() {
    playerScoreEl.textContent = playerScore
    cpuScoreEl.textContent = cpuScore
  }

  function updateResult(message) {
    resultEl.textContent = message
  }

  function resetScores() {
    playerScore = 0
    cpuScore = 0
    updateScores()
    updateResult('Score reset. Good luck!')
  }
</script>

<style>
  .rps {
    border: 1px solid #e0e0e0;
    border-radius: 10px;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.25rem;
    text-align: center;
  }

  header p {
    margin: 0;
    color: #555;
    font-size: 0.9rem;
  }

  .scoreboard {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
  }

  .scoreboard span {
    display: block;
    font-size: 0.75rem;
    color: #777;
  }

  .scoreboard strong {
    font-size: 1.4rem;
  }

  .result {
    min-height: 1.2rem;
    font-weight: 500;
  }

  .choices {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
  }

  button {
    background: #fff;
    border: 1px solid #d0d0d0;
    border-radius: 999px;
    cursor: pointer;
    font-size: 0.85rem;
    padding: 0.45rem 0.9rem;
  }

  button:hover,
  button:focus-visible {
    background: #f7f7f7;
  }

  .reset {
    align-self: center;
    border-radius: 6px;
  }

  @media (max-width: 600px) {
    .rps {
      padding: 1rem;
    }
  }
</style>
