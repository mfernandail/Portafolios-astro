---
import Icon from '../Icon.astro'
import Section from '../Section.astro'
import { skills } from '@cv'
---

<Section title="Skills">
  <ul>
    {
      skills.map((skill) => {
        //const Icon = getSkillIcon(skill.name)

        return (
          <li title={skill.name}>
            <span>{skill.name}</span>
            <Icon name={skill.name} aria-hidden="true" />
          </li>
        )
      })
    }
  </ul>

  <hr />
</Section>

<style>
  ul {
    margin-top: 10px;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    color: #000;
    list-style: none;
    padding: 0;
  }

  li {
    align-items: center;
    display: flex;
    font-size: 0.8rem;
    font-weight: 500;
    gap: 10px;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    background-color: #f0f0f0;
    transition: background-color 0.2s ease;
  }

  hr {
    margin-top: 20px;
    border: none;
    border-top: 1px dotted #d0d0d0a3;
  }
</style>
